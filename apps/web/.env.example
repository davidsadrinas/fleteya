# =============================================================================
# FleteYa — apps/web (Next.js)
# Copiá a .env.local (local) y/o configurá las mismas claves en Vercel (Production).
# Nunca commitees .env / .env.local.
# =============================================================================

# --- Supabase (obligatorio para app + middleware + API con sesión) -----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Una de las dos (dashboard → Connect / API). La clave nueva suele ser sb_publishable_…
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor (admin / bypass RLS). No la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Asignación conductor ↔ envío (postulaciones on-demand + estrategia en código)
# Bearer token para POST /api/shipments/[id]/assign (alternativa al auto-asignar abajo)
ASSIGNMENT_RUN_SECRET=
# proximity_then_rating_v1 = bandas de cercanía y luego mejor rating; default_v1 = legado
ASSIGNMENT_STRATEGY_ID=proximity_then_rating_v1
# Tras cada POST /applications intenta asignar (requiere SUPABASE_SERVICE_ROLE_KEY + migraciones RPC)
AUTO_ASSIGN_ON_APPLICATION=true

# --- Postgres (solo tu máquina: pnpm db:migrate / db:seed) ----------------------
# Session pooler recomendado si falla la conexión directa (IPv6).
# Alternativa: SUPABASE_DB_URL (mismo valor).
# DATABASE_URL=postgresql://postgres.your_ref:PASSWORD@aws-0-....pooler.supabase.com:5432/postgres

# --- URLs de la app ------------------------------------------------------------
# Local: http://localhost:3000  |  Producción: https://tu-dominio.com
# IMPORTANTE: en Vercel Production, este valor NO debe apuntar a localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (cuando implementes /api/auth). Misma base URL que NEXT_PUBLIC_APP_URL en cada entorno.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- OAuth en Supabase (Google / Facebook) --------------------------------------
# Los botones de login usan Supabase Auth: Client ID/Secret van en el Dashboard
# (Authentication → Providers), no hace falta duplicarlos acá salvo que uses NextAuth u otro flujo.
# Ver CURSOR_GUIDE.md PASO 0 → "2b. Activar proveedores de Auth".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Facebook en la UI del login (Google y email magic link siempre visibles).
# true = mostrar "Continuar con Facebook" (activá también el provider en Supabase).
# Próximas redes (ej. Instagram) pueden seguir el mismo patrón con flags dedicados.
NEXT_PUBLIC_ENABLE_FACEBOOK_AUTH=

# --- Google Maps (opcional, cuando uses mapas en la UI) -----------------------
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- MercadoPago (obligatorio para cobros) ------------------------------------
# Selección de adapter de pago (actual: mercadopago)
PAYMENT_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
# HMAC-SHA256 secret para verificar webhooks IPN de MercadoPago
MERCADOPAGO_WEBHOOK_SECRET=

# --- Web Push (VAPID keys) ---------------------------------------------------
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Admin -------------------------------------------------------------------
# Bearer token para endpoint interno de push notifications
PUSH_SEND_SECRET=

# --- Error Tracking (Sentry, opcional) ----------------------------------------
# Selección de adapter de error reporting (actual: sentry)
ERROR_REPORTING_PROVIDER=sentry
# Generar en sentry.io → Settings → Projects → DSN
NEXT_PUBLIC_SENTRY_DSN=

# --- Upstash Redis (rate limiting distribuido, opcional) ----------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# SERVICIOS NUEVOS (todos opcionales — degradan gracefully si no se configuran)
# =============================================================================

# --- RENAPER / Verificación de Identidad (Nosis u otro proveedor) -----------
# Proveedor de verificación de identidad (actual: renaper)
RENAPER_PROVIDER=renaper
RENAPER_API_URL=https://api.nosis.com/v1
RENAPER_API_KEY=
RENAPER_API_SECRET=

# --- OCR / Google Cloud Vision ----------------------------------------------
# Selección de adapter OCR (actual: google-vision)
OCR_PROVIDER=google-vision
# Service account JSON en base64: cat service-account.json | base64
GOOGLE_CLOUD_CREDENTIALS_JSON=

# --- Email Transaccional (Resend) -------------------------------------------
# Selección de adapter de email (resend | dry-run)
EMAIL_PROVIDER=resend
# Crear cuenta en resend.com, agregar dominio, copiar API key
RESEND_API_KEY=
EMAIL_FROM=FleteYa <no-reply@fleteya.com.ar>
EMAIL_REPLY_TO=soporte@fleteya.com.ar

# --- AFIP Facturación Electrónica -------------------------------------------
# Selección de adapter de billing (actual: afip)
BILLING_PROVIDER=afip
# Requiere certificado digital tramitado con clave fiscal en AFIP
AFIP_CUIT=
AFIP_CERT_PATH=./certs/afip.crt
AFIP_KEY_PATH=./certs/afip.key
AFIP_ENVIRONMENT=testing
AFIP_PUNTO_VENTA=1

# --- WhatsApp Business API (Meta Cloud API) ---------------------------------
# Selección de adapter de WhatsApp (meta | dry-run)
WHATSAPP_PROVIDER=meta
# Configurar en developers.facebook.com → WhatsApp product
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Seguro de Carga --------------------------------------------------------
# Proveedor de seguros (internal | cargo_http)
CARGO_INSURANCE_PROVIDER=internal
CARGO_INSURANCE_API_URL=
CARGO_INSURANCE_API_KEY=
CARGO_INSURANCE_COMMISSION_RATE=0.10

# --- SMS Transaccional (Twilio) ---------------------------------------------
# Selección de adapter de SMS (twilio | dry-run)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Google Directions (rutas reales, server-side) --------------------------
# Selección de adapter de ruteo (google | haversine)
ROUTING_PROVIDER=google
# Key sin restricción de HTTP referrer. Si no se configura, usa NEXT_PUBLIC_GOOGLE_MAPS_KEY.
GOOGLE_DIRECTIONS_API_KEY=

# --- Analytics (PostHog) ----------------------------------------------------
# Selección de adapter de analytics (actual: posthog)
ANALYTICS_PROVIDER=posthog
# Crear cuenta en posthog.com o self-host
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
