# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the new publishable key (dashboard “Connect”) or the legacy anon JWT:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Postgres URI para pnpm db:migrate / db:seed (psql). Si "Connection refused" con db.xxx.supabase.co,
# usá Session pooler (Connect → Session mode): host *.pooler.supabase.com y usuario postgres.<project_ref>
# (no uses solo "postgres" o falla la auth en el pooler).
# DATABASE_URL=

# Auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000
