# FleteYa — apps/mobile (Expo)
# Copiá a .env y reiniciá el bundler (los EXPO_PUBLIC_* se inyectan en build).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Una de las dos (misma lógica que en web).
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Base URL de la API Next.js (local o Vercel).
EXPO_PUBLIC_API_URL=http://localhost:3000/api
