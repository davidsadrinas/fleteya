{
  "expo": {
    "name": "FleteYa",
    "slug": "fletaya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fletaya",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fletaya.app",
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FleteYa necesita tu ubicación para mostrarte fleteros cercanos y hacer tracking de envíos.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FleteYa necesita tu ubicación en segundo plano para compartir tu posición durante un viaje activo.",
        "NSCameraUsageDescription": "FleteYa necesita acceso a la cámara para verificar tu identidad (foto del DNI y selfie).",
        "NSPhotoLibraryUsageDescription": "FleteYa necesita acceso a tus fotos para subir documentos de verificación."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B4332"
      },
      "package": "com.fletaya.app",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_KEY"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF7F6B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
